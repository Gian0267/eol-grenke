{
  "name": "@nsm-eol/backend",
  "version": "0.1.0",
  "private": true,
  "description": "Backend Express + Prisma per NSM EOL Grenke template",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "db:setup": "prisma generate && prisma migrate dev --name init",
    "db:seed": "tsx prisma/seed.ts",
    "db:seed:timeline": "tsx prisma/seed-timeline.ts",
    "db:reset": "prisma migrate reset --force && npm run db:seed",
    "db:studio": "prisma studio",
    "typecheck": "tsc --noEmit",
    "lint": "echo 'lint placeholder'",
    "test": "echo 'test placeholder'",
    "demo:reset": "prisma migrate reset --force && tsx prisma/seed.ts && tsx prisma/seed-demo.ts"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/express-session": "^1.19.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.6.2",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^8.0.0",
    "@types/passport": "^1.0.17",
    "@types/passport-local": "^1.0.38",
    "@types/pdfkit": "^0.17.6",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "@types/multer": "^2.1.0",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^16.6.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.1",
    "express-session": "^1.19.0",
    "handlebars": "^4.7.9",
    "iconv-lite": "^0.7.2",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.7",
    "passport": "^0.7.0",
    "passport-local": "^1.0.0",
    "pdfkit": "^0.18.0",
    "xlsx": "^0.18.5",
    "zod": "^4.4.3"
  }
}
