generator client {
  provider = "prisma-client-js"
  // Motore "binary" (processo separato) invece della libreria nativa in-process:
  // necessario su Hostinger/LiteSpeed, dove il fork dei worker rompe i timer
  // del motore library ("PANIC: timer has gone away" a ogni query).
  engineType = "binary"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Contratto_EOL {
  id                    String               @id @default(uuid())
  contratto_nsm_id      String               @unique // corrispondenza 1:1 con il contratto Grenke
  contratto_grenke_id   String
  cliente_id            String
  cliente               Cliente              @relation(fields: [cliente_id], references: [id])
  data_stipula          DateTime
  data_scadenza         DateTime?            // assente finché il contratto non compare in un file Grenke
  canone_mensile        Decimal
  numero_mesi           Int
  monte_canoni          Decimal
  valore_originario     Decimal?
  beni_json             String               // SQLite doesn't support JSON type natively, using String
  pricing_riacquisto    Decimal
  pricing_grenke        Decimal
  margine_lordo         Decimal
  valore_gift_card      Decimal
  stato                 String
  origine               String
  agente_originario_id  String?
  agente_originario     Utente_NSM?          @relation("AgenteOriginario", fields: [agente_originario_id], references: [id])
  agente_assegnato_id   String?
  agente_assegnato      Utente_NSM?          @relation("AgenteAssegnato", fields: [agente_assegnato_id], references: [id])
  data_importazione     DateTime
  token_accesso_cliente String?
  stato_riconciliazione String
  created_at            DateTime             @default(now())
  updated_at            DateTime             @updatedAt

  decisioni             Decisione_Cliente[]
  pagamenti             Pagamento[]
  comunicazioni         Comunicazione[]
  richieste_contatto    Richiesta_Contatto[]
  audit_events          Audit_Event[]
  task_escalation       Task_Escalation[]
  codici_sconto         Codice_Sconto[]

  @@index([contratto_grenke_id])
  @@index([stato])
  @@index([data_scadenza])
}

model Cliente {
  id                    String          @id @default(uuid())
  ragione_sociale       String
  piva                  String          @unique
  codice_fiscale        String?
  email                 String
  pec                   String?
  telefono              String?
  referente_nome        String?
  referente_email       String?
  referente_telefono    String?
  indirizzo_sede        String?
  cap                   String?
  citta                 String?
  provincia             String?
  opt_out_comunicazioni Boolean         @default(false)
  created_at            DateTime        @default(now())
  updated_at            DateTime        @updatedAt

  contratti             Contratto_EOL[]
}

model Decisione_Cliente {
  id                String        @id @default(uuid())
  contratto_eol_id  String
  contratto_eol     Contratto_EOL @relation(fields: [contratto_eol_id], references: [id])
  opzione_scelta    String
  data_decisione    DateTime      @default(now())
  ip_address        String?
  user_agent        String?
  otp_verificato    Boolean       @default(false)
  otp_metodo        String?
  pdf_conferma_path String?
  hash_pdf          String?
  note_cliente      String?
  created_at        DateTime      @default(now())
}

model Pagamento {
  id                      String        @id @default(uuid())
  contratto_eol_id        String
  contratto_eol           Contratto_EOL @relation(fields: [contratto_eol_id], references: [id])
  importo_netto           Decimal
  importo_iva             Decimal
  importo_totale          Decimal
  metodo                  String
  stato                   String
  session_id              String?              @unique
  riferimento_transazione String?
  data_iniziato           DateTime      @default(now())
  data_completato         DateTime?
  fattura_numero          String?
  fattura_path            String?
  natura_giuridica        String
}

model Comunicazione {
  id               String        @id @default(uuid())
  contratto_eol_id String
  contratto_eol    Contratto_EOL @relation(fields: [contratto_eol_id], references: [id])
  tipo             String
  canale           String
  destinatario     String
  oggetto          String?
  corpo_html       String?
  esito_chiamata   String?
  allegati_json    String?       // Stored as String since SQLite doesn't have native JSON
  data_invio       DateTime      @default(now())
  data_consegna    DateTime?
  data_apertura    DateTime?
  esito_invio      String
  operatore_id     String?
  operatore        Utente_NSM?   @relation(fields: [operatore_id], references: [id])
  created_at       DateTime      @default(now())

  @@index([contratto_eol_id, tipo])
}

model Richiesta_Contatto {
  id                  String        @id @default(uuid())
  contratto_eol_id    String
  contratto_eol       Contratto_EOL @relation(fields: [contratto_eol_id], references: [id])
  origine             String
  nome_referente      String?
  telefono            String?
  giorno_preferito    String?
  fascia_oraria       String?
  modalita_preferita  String?
  note                String?
  agente_assegnato_id String?
  agente_assegnato    Utente_NSM?   @relation(fields: [agente_assegnato_id], references: [id])
  stato               String
  data_richiamato     DateTime?
  esito               String?
  pratica_sbloccata   Boolean       @default(false)
  created_at          DateTime      @default(now())
}

model Audit_Event {
  id               String         @id @default(uuid())
  contratto_eol_id String?
  contratto_eol    Contratto_EOL? @relation(fields: [contratto_eol_id], references: [id])
  timestamp        DateTime       @default(now())
  attore_tipo      String
  attore_id        String
  azione           String
  dati_json        String
  hash_precedente  String
  hash_corrente    String
}

model OtpCode {
  id           String   @id @default(uuid())
  destinatario String
  codice       String
  metodo       String
  scadenza     DateTime
  usato        Boolean  @default(false)
  created_at   DateTime @default(now())
}

model Counter {
  id    String @id @default(uuid())
  year  Int
  type  String
  value Int    @default(0)

  @@unique([year, type])
}

model Utente_NSM {
  id            String   @id @default(uuid())
  nome          String
  cognome       String
  email         String   @unique
  password      String
  ruolo         String
  attivo        Boolean  @default(true)
  created_at    DateTime @default(now())
  superiore_id  String?

  // Self-relation: gerarchia AGENZIA → CAPO_AREA → GROUP_MANAGER → AGENTE → JUNIOR_AGENT
  superiore     Utente_NSM?  @relation("Gerarchia", fields: [superiore_id], references: [id])
  subordinati   Utente_NSM[] @relation("Gerarchia")

  // Relations
  contratti_originati  Contratto_EOL[]      @relation("AgenteOriginario")
  contratti_assegnati  Contratto_EOL[]      @relation("AgenteAssegnato")
  chiamate_effettuate  Comunicazione[]
  richieste_assegnate  Richiesta_Contatto[]
  task_assegnati       Task_Escalation[]
  impostazioni_modificate Impostazione[]
}

model Impostazione {
  id             String    @id @default(uuid())
  chiave         String    @unique
  valore         String
  tipo           String
  categoria      String
  label          String
  descrizione    String
  valore_default String
  updated_at     DateTime  @updatedAt
  updated_by_id  String?
  updated_by     Utente_NSM? @relation(fields: [updated_by_id], references: [id])

  @@index([categoria])
}

model Codice_Sconto {
  id               String        @id @default(uuid())
  codice           String        @unique // formato NSM-XXXX-XXXX (charset senza 0/O/1/I/L)
  valore_eur       Decimal
  contratto_eol_id String
  contratto_eol    Contratto_EOL @relation(fields: [contratto_eol_id], references: [id])
  cliente_id       String
  piva_cliente     String // denormalizzata per lookup rapido dalla piattaforma noleggio
  stato            String        @default("GENERATO") // GENERATO | UTILIZZATO | SCADUTO | ANNULLATO
  data_generazione DateTime      @default(now())
  data_scadenza    DateTime
  data_utilizzo    DateTime?
  note             String?
  created_at       DateTime      @default(now())
  updated_at       DateTime      @updatedAt

  @@index([contratto_eol_id])
  @@index([stato])
  @@index([piva_cliente])
}

model Task_Escalation {
  id                  String        @id @default(uuid())
  contratto_eol_id    String
  contratto_eol       Contratto_EOL @relation(fields: [contratto_eol_id], references: [id])
  tipo                String
  assegnato_a_id      String
  assegnato_a         Utente_NSM    @relation(fields: [assegnato_a_id], references: [id])
  stato               String        @default("DA_CHIAMARE")
  data_creazione      DateTime      @default(now())
  data_completamento  DateTime?
  esito               String?
  note                String?

  @@index([assegnato_a_id, stato])
}
